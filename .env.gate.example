# Copy to .env.gate and fill with local values (never commit .env.gate)
# DEPLOY_ENV value example: staging
DEPLOY_ENV=
# BASE_URL format: https://api-staging.example.com
BASE_URL=
# DATABASE_URL format: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
# MEMORYNODE_API_KEY placeholder: MEMORYNODE_API_KEY_PLACEHOLDER
MEMORYNODE_API_KEY=
# DEPLOY_CONFIRM value example: memorynode-prod
DEPLOY_CONFIRM=
# CLOUDFLARE_API_TOKEN placeholder: CLOUDFLARE_API_TOKEN_PLACEHOLDER
CLOUDFLARE_API_TOKEN=
# DRY_RUN value example: 1
DRY_RUN=
