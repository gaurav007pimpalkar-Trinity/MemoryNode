## Copy to .env.prod.smoke and fill before prod release check; DO NOT commit.
# DEPLOY_ENV example: production
DEPLOY_ENV=
# BASE_URL format: https://api.example.com
BASE_URL=
# DATABASE_URL format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=
# SUPABASE_URL format: https://your-project.supabase.co
SUPABASE_URL=
# API_KEY_SALT placeholder: PROD_API_KEY_SALT_PLACEHOLDER
API_KEY_SALT=
# MASTER_ADMIN_TOKEN placeholder: PROD_MASTER_ADMIN_TOKEN_PLACEHOLDER
MASTER_ADMIN_TOKEN=
# EMBEDDINGS_MODE values: openai | stub
EMBEDDINGS_MODE=
# OPENAI_API_KEY placeholder: OPENAI_API_KEY_PLACEHOLDER
OPENAI_API_KEY=
# MEMORYNODE_API_KEY placeholder: MEMORYNODE_API_KEY_PLACEHOLDER
MEMORYNODE_API_KEY=
# RATE_LIMIT_DO placeholder: prod-do-binding
RATE_LIMIT_DO=
# BUILD_VERSION placeholder: 2026.02.10-abcdef0
BUILD_VERSION=
# STRIPE_SECRET_KEY placeholder: STRIPE_SECRET_KEY_PLACEHOLDER
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET placeholder: STRIPE_WEBHOOK_SECRET_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=
# CLOUDFLARE_API_TOKEN placeholder: CLOUDFLARE_API_TOKEN_PLACEHOLDER
CLOUDFLARE_API_TOKEN=
# DEPLOY_CONFIRM value example: memorynode-prod
DEPLOY_CONFIRM=
# DRY_RUN value example: 1
DRY_RUN=
